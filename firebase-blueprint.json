{
  "entities": {
    "user": {
      "title": "User Account",
      "description": "A user's subscription and account details",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Unique identifier for the user" },
        "password": { "type": "string", "description": "Login password" },
        "planName": { "type": "string", "description": "Name of the subscription plan" },
        "planPrice": { "type": "string", "description": "Price of the plan" },
        "expiryDate": { "type": "string", "format": "date", "description": "When the plan expires" },
        "features": { "type": "array", "items": { "type": "string" }, "description": "Features included in the plan" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "password", "planName"]
    },
    "movieRequest": {
      "title": "Movie Request",
      "description": "A request for a movie or series from a user",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The name of the movie or series"
        },
        "year": {
          "type": "string",
          "description": "The release year"
        },
        "category": {
          "type": "string",
          "enum": ["Movie", "Web Series"],
          "description": "The type of content"
        },
        "language": {
          "type": "string",
          "description": "Preferred language"
        },
        "note": {
          "type": "string",
          "description": "Additional user notes"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "solved"],
          "description": "Current status of the request"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the request was made"
        },
        "userName": {
          "type": "string",
          "description": "IP or identifier of the user"
        }
      },
      "required": ["title", "category", "timestamp"]
    },
    "planRequest": {
      "title": "Plan Change Request",
      "description": "A request to upgrade or extend a subscription",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["upgrade", "extension"] },
        "days": { "type": "number", "description": "Number of days requested for extension" },
        "planName": { "type": "string", "description": "Target plan for upgrade" },
        "transactionId": { "type": "string", "description": "Payment UTR/Transaction ID" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "status", "timestamp"]
    },
    "setting": {
      "title": "System Setting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "upiId": { "type": "string", "description": "Payment UPI ID (e.g. user@bank)" },
        "merchantName": { "type": "string", "description": "Owner name for payment" }
      }
    }
  },
  "firestore": {
    "/requests/{requestId}": {
      "schema": "movieRequest",
      "description": "Collection of movie requests"
    },
    "/upgradeRequests/{requestId}": {
      "schema": "planRequest",
      "description": "Collection of plan change requests"
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user identities and subscription plans"
    },
    "/settings/{settingId}": {
      "schema": "setting",
      "description": "App settings like UPI IDs"
    }
  }
}
